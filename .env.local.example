# ============================================================================
# Exemple de variables d'environnement locales.
# Copier vers .env.local et remplir avec les vraies valeurs du projet.
# .env.local est gitignored (voir .gitignore).
# ============================================================================

# --- Supabase ---
# Dashboard projet → Settings → API → Project URL + anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# Service role key : NE JAMAIS commiter, NE JAMAIS exposer au client.
# Utilisée uniquement côté serveur (edge functions, jobs, seed scripts).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...
